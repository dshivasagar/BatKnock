{
  "expo": {
    "name": "BatKnock",
    "slug": "batknock",
    "version": "1.3.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#111b21"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.batknock.app",
      "buildNumber": "2",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "BatKnock uses the microphone to detect and count bat knocking sounds during preparation sessions.",
        "NSCameraUsageDescription": "BatKnock uses the camera to take photos of your bat.",
        "UIBackgroundModes": ["audio", "audio"],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#111b21"
      },
      "package": "com.batknock.app",
      "versionCode": 4,
      "permissions": ["RECORD_AUDIO", "MODIFY_AUDIO_SETTINGS", "VIBRATE"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "045ba8e6-a7d0-450f-8e15-a5224f721029"
      }
    },
    "owner": "dshivasagar.auto"
  }
}
