{
  "expo": {
    "name": "Knockmate",
    "slug": "batknock",
    "version": "1.1.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#111b21"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.batknock.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Knockmate uses the microphone to detect and count bat knocking sounds during preparation sessions.",
        "NSCameraUsageDescription": "Knockmate uses the camera to take photos of your bat.",
        "UIBackgroundModes": [
          "audio",
          "audio"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserNotificationUsageDescription": "Knockmate sends reminders when your bat is ready for the next preparation phase."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#111b21"
      },
      "package": "com.batknock.app",
      "versionCode": 3,
      "permissions": [
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "045ba8e6-a7d0-450f-8e15-a5224f721029"
      }
    },
    "owner": "dshivasagar.auto"
  }
}